# Backups created by install.ps1
*.backup

# Secrets — never commit these
.env
*.key
*.pem
id_rsa
id_ed25519

# Windows junk
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Editor
.vscode/
*.swp

# Bundled Python projects (local venv + secrets + cache — never commit)
projects/**/.venv/
projects/**/__pycache__/
projects/**/*.pyc
projects/**/cookies.txt

# mpv-config — see mpv-config/.gitignore for shader cache, watch_later, etc.
