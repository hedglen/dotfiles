# foobar2000 theme .gitignore
# Ignore user-specific files and temporary data

# User preferences
*.cfg.bak
*.fpl
*.m3u
*.m3u8

# Cache and temporary files
*.tmp
*.cache
*.log

# Component downloads
*.fb2k-component
*.dll

# User data
playlists/
cache/
index-data/

# Keep theme files
!theme/
!*.md
!*.ps1
!*.txt
