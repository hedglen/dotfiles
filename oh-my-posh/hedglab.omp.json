{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "{{ .Folder }} — {{ .Shell }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "shell",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "foreground": "#0E0E0E",
          "background": "#E954FF",
          "template": " {{ .Name }} ",
          "properties": {
            "mapped_shell_names": {
              "pwsh": "\uebc7 pwsh",
              "powershell": "\uebc7 powershell"
            }
          }
        },
        {
          "properties": {
            "folder_separator_icon": " / ",
            "style": "full"
          },
          "foreground": "#66F9FF",
          "background": "#1B2B38",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "display_stash_count": true,
            "display_status": true,
            "branch_icon": "\ue0a0"
          },
          "foreground": "#0E0E0E",
          "background": "#FFD447",
          "type": "git",
          "style": "powerline"
        },
        {
          "foreground": "#0E0E0E",
          "background": "#00E8B5",
          "type": "executiontime",
          "style": "powerline"
        },
        {
          "foreground": "#FFFFFF",
          "background": "#FF6B8A",
          "type": "exit",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#64B5FF",
          "template": " \uf017 {{ .CurrentDate | date .Format }} ",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ]
    }
  ]
}
