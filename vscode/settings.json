{
  // =============================================================================
  //   Theme & Appearance
  // =============================================================================
  "workbench.colorTheme": "SynthWave '84",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.tree.indent": 16,
  "workbench.editor.enablePreview": false,
  "workbench.editor.tabSizing": "shrink",

  // =============================================================================
  //   Editor — Core
  // =============================================================================
  "editor.fontFamily": "'Cascadia Code', 'Fira Code', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.wordWrap": "off",
  "editor.rulers": [100],

  // =============================================================================
  //   Editor — Visual Aids
  // =============================================================================
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderLineHighlight": "all",

  // =============================================================================
  //   Editor — Animation & Feel
  // =============================================================================
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,

  // =============================================================================
  //   Editor — Suggestions & Completions
  // =============================================================================
  "editor.inlineSuggest.enabled": true,
  "editor.suggest.preview": true,
  "editor.suggest.insertMode": "replace",
  "editor.acceptSuggestionOnCommitCharacter": false,

  // =============================================================================
  //   Editor — Save Behavior
  // =============================================================================
  "editor.formatOnSave": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.autoSave": "onFocusChange",

  // =============================================================================
  //   Terminal
  // =============================================================================
  "terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font', 'Cascadia Code', Consolas",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.scrollbar.verticalScrollbarSize": 12,
  "terminal.integrated.background": "#0A0A0F",
  "terminal.integrated.foreground": "#39FF14",
  "terminal.integrated.ansiBlack": "#1C1C2E",
  "terminal.integrated.ansiBlue": "#BF00FF",
  "terminal.integrated.ansiCyan": "#00FFCC",
  "terminal.integrated.ansiGreen": "#39FF14",
  "terminal.integrated.ansiRed": "#FF2D55",
  "terminal.integrated.ansiYellow": "#FF6000",
  "terminal.integrated.ansiWhite": "#D0D0E0",
  "terminal.integrated.ansiMagenta": "#FF00CC",
  "terminal.integrated.ansiBrightBlack": "#39FF14",
  "terminal.integrated.ansiBrightBlue": "#D966FF",
  "terminal.integrated.ansiBrightCyan": "#40FFE0",
  "terminal.integrated.ansiBrightGreen": "#7FFF00",
  "terminal.integrated.ansiBrightRed": "#FF6080",
  "terminal.integrated.ansiBrightYellow": "#FF8C00",
  "terminal.integrated.ansiBrightWhite": "#FFFFFF",

  "workbench.colorCustomizations": {
    "terminal.background": "#0A0A0F",
    "terminal.foreground": "#39FF14",
    "terminalCursor.background": "#39FF14",
    "terminalCursor.foreground": "#39FF14",
    "terminal.ansiBlack": "#1C1C2E",
    "terminal.ansiBlue": "#BF00FF",
    "terminal.ansiCyan": "#00FFCC",
    "terminal.ansiGreen": "#39FF14",
    "terminal.ansiRed": "#FF2D55",
    "terminal.ansiYellow": "#FF6000",
    "terminal.ansiWhite": "#D0D0E0",
    "terminal.ansiBrightBlack": "#39FF14",
    "terminal.ansiBrightBlue": "#D966FF",
    "terminal.ansiBrightCyan": "#40FFE0",
    "terminal.ansiBrightGreen": "#7FFF00",
    "terminal.ansiBrightRed": "#FF6080",
    "terminal.ansiBrightYellow": "#FF8C00",
    "terminal.ansiBrightWhite": "#FFFFFF",
  },

  // =============================================================================
  //   Explorer
  // =============================================================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/dist": true,
    "**/__pycache__": true,
  },

  // =============================================================================
  //   Git
  // =============================================================================
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // =============================================================================
  //   Extensions — Claude Code
  // =============================================================================
  "security.workspace.trust.untrustedFiles": "open",
  "claudeCode.preferredLocation": "panel",

  // =============================================================================
  //   Extensions — GitLens
  // =============================================================================
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4o-mini",
  "gitlens.codeLens.enabled": false,

  // =============================================================================
  //   Extensions — Copilot
  // =============================================================================
  "github.copilot.enable": {
    "*": true,
  },

  // =============================================================================
  //   Language — PowerShell
  // =============================================================================
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
  },
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.scriptAnalysis.enable": true,

  // =============================================================================
  //   Language — Python
  // =============================================================================
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
  },
  "python.languageServer": "Pylance",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,

  // =============================================================================
  //   Language — AutoHotkey
  // =============================================================================
  "AutoHotkey2.InterpreterPath": "C:\\Users\\rjh\\AppData\\Local\\Microsoft\\WindowsApps\\AutoHotkeyV2.exe",

  // =============================================================================
  //   Language — Lua
  // =============================================================================
  "[lua]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "sumneko.lua",
  },
  "Lua.diagnostics.globals": ["mp", "mp_event_loop"],
  "Lua.workspace.library": [],

  // =============================================================================
  //   Language — JSON / YAML
  // =============================================================================
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  // =============================================================================
  //   Language — Markdown
  // =============================================================================
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": false,
    },
  },
  "workbench.startupEditor": "none",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "chat.tools.terminal.autoApprove": true,
  "workbench.scrollbar.verticalScrollbarSize": 14,
  "editor.scrollbar.verticalScrollbarSize": 14,
  "cSpell.userWords": ["autohotkey", "hedglen"],
}
