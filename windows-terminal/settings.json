  "copyFormatting": "none",
  "copyOnSelect": false,
  "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
  "initialCols": 120,
  "initialRows": 30,
  "tabWidthMode": "titleLength",

  "actions": [
    { "id": "Terminal.CopyToClipboard", "keys": "ctrl+c" },
    { "id": "Terminal.PasteFromClipboard", "keys": "ctrl+v" },
    { "id": "Terminal.DuplicatePaneAuto", "keys": "alt+shift+d" },
    { "id": "Terminal.NewTab", "keys": "ctrl+t" },
    { "id": "Terminal.CloseTab", "keys": "ctrl+w" },
    { "id": "Terminal.NextTab", "keys": "ctrl+tab" },
    { "id": "Terminal.PrevTab", "keys": "ctrl+shift+tab" },
    { "id": "Terminal.SplitRight", "keys": "alt+shift+right" },
    { "id": "Terminal.SplitDown", "keys": "alt+shift+down" }
  ],

  "profiles": {
